{
  "entities": {
    "Booking": {
      "title": "Booking",
      "description": "A booking made by a tourist for a service.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "touristUid": { "type": "string" },
        "touristName": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceName": { "type": "string" },
        "serviceType": { "type": "string", "enum": ["STAY", "TRANSPORT", "TOUR"] },
        "businessId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["PENDING", "CONFIRMED", "CANCELLED"] },
        "amount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["touristUid", "serviceId", "serviceType", "status", "amount", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user profile (Tourist, Business Owner, or LGU Staff).",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["TOURIST", "BUSINESS", "LGU"] },
        "businessId": { "type": "string", "description": "Only for BUSINESS role" }
      },
      "required": ["uid", "name", "email", "role"]
    }
  },
  "firestore": {
    "/bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Collection of all bookings."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles."
    }
  }
}
