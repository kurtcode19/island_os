rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {};
    }

    function hasRole(role) {
      return isAuthenticated() && getUserData().get('role', '') == role;
    }

    function isAdmin() {
      return isAuthenticated() && (
        request.auth.token.email == "kurtmier123@gmail.com" || 
        getUserData().get('role', '') == 'LGU'
      );
    }

    function isBusinessOwner(businessId) {
      let data = getUserData();
      return isAuthenticated() && data.get('role', '') == 'BUSINESS' && data.get('businessId', '') == businessId;
    }

    // ===============================================================
    // Match Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /bookings/{bookingId} {
      allow read, write: if isAuthenticated();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
